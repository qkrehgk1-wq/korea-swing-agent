DATABASE_URL=
JWT_SECRET=
VITE_APP_ID=
OAUTH_SERVER_URL=
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=

# ── LLM providers (fallback chain) ──
# invokeLLM tries providers in LLM_PROVIDER_ORDER until one succeeds, so a
# capped or rate-limited key transparently falls through to the next provider.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
# Priority order — reorder to skip a capped provider, e.g. openai,gemini,anthropic
LLM_PROVIDER_ORDER=anthropic,openai,gemini,openrouter,forge
LLM_EFFORT=high

# Forge gateway (OpenAI-compatible) — last-resort fallback.
FORGE_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=4096

# Korean stock analysis
# Auto mode: if keys exist, official DART/KRX MCP data is used in addition to pykrx price analysis.
DART_API_KEY=
KRX_API_KEY=
KOREAN_STOCK_MCP_ENABLED=true

# KakaoTalk daily memo to yourself
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
KAKAO_WEB_URL=http://localhost:3001/dashboard/analysis

# Telegram daily alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional external intelligence integrations
# CSV exports are safest for batch mode. MCP URLs can be used when Oriane/Waydev provide remote MCP endpoints.
ORIANE_EXPORT_PATH=
ORIANE_MCP_URL=
ORIANE_MCP_TOKEN=
ORIANE_MCP_TOOL=search_video_intelligence
WAYDEV_EXPORT_PATH=
WAYDEV_MCP_URL=
WAYDEV_MCP_TOKEN=
WAYDEV_MCP_TOOL=get_engineering_feed

# Optional Airbyte MCP/API integration
# Put real values in .env only. Do not commit secrets in this example file.
AIRBYTE_ORGANIZATION_ID=
AIRBYTE_WORKSPACE_ID=
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_EXPORT_PATH=
AIRBYTE_MCP_URL=
AIRBYTE_MCP_TOKEN=
AIRBYTE_MCP_TOOL=list_connections
